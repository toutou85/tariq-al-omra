  <!-- ===== Scripts ===== -->
  <script>
    /* DateTime */
    function updateDateTime() {
      const now = new Date();
      const opts = { weekday:'short', year:'numeric', month:'short', day:'numeric' };
      document.getElementById("datetime").textContent =
        now.toLocaleDateString('ar-DZ', opts) + ' ' + now.toLocaleTimeString('ar-DZ');
    }
    setInterval(updateDateTime, 1000);
    updateDateTime();

    /* Scroll effect on top bar */
    window.addEventListener('scroll', () => {
      document.getElementById('topBar').classList.toggle('scrolled', window.scrollY > 40);
    });

    /* Sidebar */
    function openSidebar() {
      document.getElementById("mySidebar").classList.add("open");
      document.getElementById("sidebarOverlay").classList.add("open");
      document.body.style.overflow = "hidden";
    }
    function closeSidebar() {
      document.getElementById("mySidebar").classList.remove("open");
      document.getElementById("sidebarOverlay").classList.remove("open");
      document.body.style.overflow = "";
    }

    /* Particle generator */
    (function generateParticles() {
      const container = document.getElementById('particles');
      for (let i = 0; i < 60; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        p.style.cssText = `
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          --dur: ${3 + Math.random() * 5}s;
          --delay: ${Math.random() * 6}s;
          width: ${1 + Math.random() * 2}px;
          height: ${1 + Math.random() * 2}px;
        `;
        container.appendChild(p);
      }
    })();

    /* Notifications */
    const userEmail = localStorage.getItem("userEmail");
    if (userEmail) {
      fetch(`https://script.google.com/macros/s/AKfycbzr9XTABt-6PkmU2WzqhRAzB5e2NpwBfxwribjz5wZSm6v4QqOJ5FH563IfqGZpznZV6A/exec?email=${encodeURIComponent(userEmail)}&unread=true`)
        .then(r => r.json())
        .then(data => {
          if (Array.isArray(data) && data.length > 0) {
            const badge = document.getElementById("notif-badge");
            badge.textContent = data.length;
            badge.style.display = "inline-block";
          }
        })
        .catch(e => console.error("خطأ في الإشعارات:", e));
    }

    /* Visit tracker */
    const TRACKER_URL = "https://script.google.com/macros/s/AKfycbyT0Euxqsi7wvMdVwN1M56sP8r_3V8HIjqaS3i7sDy_nTad7catfjnRcYLHdZVPKf20/exec";
    window.addEventListener("load", () => {
      if (!localStorage.getItem("visitedOnce")) {
        fetch(TRACKER_URL, { method: "POST" })
          .then(() => { localStorage.setItem("visitedOnce", "true"); })
          .catch(e => console.error("خطأ في تتبع الزيارة:", e));
      }
    });

    /* Animate feature cards on scroll */
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.style.opacity = "1";
            entry.target.style.transform = "translateY(0)";
          }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.feature-card, .quick-card').forEach(el => {
      el.style.opacity = "0";
      el.style.transform = "translateY(20px)";
      el.style.transition = "opacity 0.5s ease, transform 0.5s ease, border-color 0.35s ease, box-shadow 0.35s ease";
      observer.observe(el);
    });
  </script>
