<script>
const SHEET_URL = "https://script.google.com/macros/s/AKfycbzu_D4Gy4PL5NLfHXsFBOQD8Se8W1kJDH3rEGna5WDZ0uTNUcgLsUGcrUIQlIzXZgj/exec";
let offersData = [];

/* ===== SIDEBAR ===== */
function openSidebar() {
  document.getElementById("mySidebar").classList.add("open");
  document.getElementById("overlay").classList.add("show");
  document.body.style.overflow = "hidden";
}
function closeSidebar() {
  document.getElementById("mySidebar").classList.remove("open");
  document.getElementById("overlay").classList.remove("show");
  document.body.style.overflow = "";
}

/* ===== LOGO ===== */
function normalizeArabic(t) {
  return String(t).toLowerCase()
    .replace(/[إأآٱ]/g, "ا").replace(/ة/g, "ه")
    .replace(/ى/g, "ي").replace(/ال/g, "")
    .replace(/[^؀-ۿ\s]/g, "").trim();
}

function getAgencyLogo(name = "") {
  const n = normalizeArabic(name);
  if (/تقرت/.test(n)) return "https://i.ibb.co/2XWLPsc/1766858356356-removebg-preview.png";
  if (/انسية|انسيه/.test(n)) return "https://i.ibb.co/Mk97KqGK/FB-IMG-1766861138141-removebg-preview.png";
  if (/سقيف/.test(n)) return "https://i.ibb.co/mmrx9QG/FB-IMG-1766861105309-removebg-preview.png";
  return "";
}

/* ===== DATE PARSE ===== */
function parseArabicDayMonth(text) {
  if (!text) return null;
  const clean = text.split("_")[0].replace(/[-–]/g, " ").replace(/\s+/g, " ").trim();
  const match = clean.match(/(\d{1,2})\s*(جانفي|فيفري|مارس|أفريل|ماي|جوان|جويلية|أوت|سبتمبر|أكتوبر|نوفمبر|ديسمبر)/);
  if (!match) return null;
  const months = { "جانفي":0,"فيفري":1,"مارس":2,"أفريل":3,"ماي":4,"جوان":5,"جويلية":6,"أوت":7,"سبتمبر":8,"أكتوبر":9,"نوفمبر":10,"ديسمبر":11 };
  return new Date(new Date().getFullYear(), months[match[2]], parseInt(match[1]));
}

/* ===== LIKE ===== */
function toggleLike(id) {
  if (localStorage.getItem("liked_" + id)) return;
  fetch(SHEET_URL + "?action=like&id=" + id)
    .then(r => r.json())
    .then(r => {
      if (r.success) {
        document.getElementById("like-" + id).textContent = r.likes;
        localStorage.setItem("liked_" + id, "1");
      }
    }).catch(() => {});
}

/* ===== CARD HTML ===== */
function buildCard(o) {
  const id = o["ID"] || Math.random().toString(36).substr(2, 9);
  const agency = o["اسم الوكالة"] || o["الوكالة"] || "وكالة سياحية";
  const logo = getAgencyLogo(agency);
  const duration = o["المدة"] || "";
  const tripDate = o["تاريخ الرحلة"] || "";
  const hotel = o["الفندق"] || "";
  const price = o["السعر الغرفة الجماعية (دج)"] || "";
  const title = o["اسم العرض"] || "عرض عمرة مميز";
  const likes = o["likes"] || 0;

  const logoHtml = logo
    ? `<img class="agency-logo" src="${logo}" alt="${agency}" onerror="this.style.display='none'">`
    : `<div class="agency-avatar">🕌</div>`;

  return `
  <div class="card">
    <div class="card-accent"></div>
    <div class="card-body">
      <div class="agency-row">
        ${logoHtml}
        <div>
          <div class="agency-name">${agency}</div>
          <div class="agency-verified">✔ وكالة معتمدة</div>
        </div>
      </div>

      <div class="offer-title">${title}</div>

      <div class="info-list">
        ${hotel ? `
        <div class="info-row">
          <div class="info-icon">🏨</div>
          <div class="info-text"><strong>${hotel}</strong></div>
        </div>` : ''}
        ${duration ? `
        <div class="info-row">
          <div class="info-icon">⏳</div>
          <div class="info-text">المدة: <strong>${duration}</strong></div>
        </div>` : ''}





${tripDate ? `
        <div class="info-row">
          <div class="info-icon">📅</div>
          <div class="info-text">تاريخ الرحلة: <strong>${tripDate}</strong></div>
        </div>` : ''}
      </div>

      <div class="price-block">
        <div>
          <div class="price-label">السعر الغرفة الجماعية</div>
          <div class="price-value">${price ? Number(price).toLocaleString('ar-DZ') : '—'} <span class="price-unit">دج</span></div>
        </div>
        <div style="font-size:28px">💰</div>
      </div>

      <div class="card-btns">
        <a class="btn btn-details" href="offer-details.html?id=${id}">📖 التفاصيل</a>
        <button class="btn btn-like" onclick="toggleLike('${id}')">
          ❤️ إعجاب <span class="like-count" id="like-${id}">${likes}</span>
        </button>
        <a class="btn btn-book" href="offer-details.html?id=${id}">🟢 احجز الآن</a>
      </div>
    </div>
  </div>`;
}

/* ===== RENDER ===== */
function renderOffers(data, filter = "all") {
  data.sort((a, b) => {
    const da = parseArabicDayMonth(a["تاريخ الرحلة"]);
    const db = parseArabicDayMonth(b["تاريخ الرحلة"]);
    if (!da && !db) return 0;
    if (!da) return 1;
    if (!db) return -1;
    return da - db;
  });

  const c = document.getElementById("offersContainer");
  c.innerHTML = "";

  const grouped = {};
  data.forEach(o => {
    const airport = (o["المطار"] || "غير محدد").trim();
    if (!grouped[airport]) grouped[airport] = [];
    grouped[airport].push(o);
  });

  let totalVisible = 0;
  let delay = 0;

  Object.keys(grouped).forEach(airport => {
    if (filter !== "all" && filter !== airport) return;

    const offers = grouped[airport];
    totalVisible += offers.length;

    const section = document.createElement("div");
    section.className = "airport-section";
    section.style.animationDelay = `${delay}s`;
    delay += 0.1;

    section.innerHTML = `
      <div class="airport-header">
        <div class="airport-icon">🛫</div>
        <div class="airport-info">
          <h2>مطار ${airport}</h2>
          <p>عروض الرحلات المتاحة</p>
        </div>
        <div class="airport-count">${offers.length} عرض</div>
      </div>
      <div class="scroll-track">${offers.map(o => buildCard(o)).join('')}</div>
    `;

    c.appendChild(section);
  });

  if (totalVisible === 0) {
    c.innerHTML = `
      <div class="empty-state">
        <div class="icon">🕌</div>
        <h3>لا توجد عروض متاحة حالياً</h3>
        <p>حاول اختيار مطار آخر أو تحقق لاحقاً</p>
      </div>`;
  }

  document.getElementById("offerCount").textContent = `✈️ ${totalVisible} عرض متاح`;
}

function renderFiltered() {
  renderOffers(offersData, document.getElementById("airportFilter").value);
}

