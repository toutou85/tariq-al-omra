  <style>
    /* ===== CSS Variables ===== */
    :root {
      --gold: #C9A84C;
      --gold-light: #F0D080;
      --gold-glow: #FFD700;
      --dark: #0A0A0F;
      --dark-2: #12121A;
      --dark-3: #1A1A28;
      --cream: #F5EDD8;
      --white: #FFFFFF;
      --text-muted: #9B9BA8;
      --border: rgba(201,168,76,0.25);
      --shadow-gold: 0 0 40px rgba(201,168,76,0.3);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Tajawal', sans-serif;
      background: var(--dark);
      color: var(--white);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ===== Scrollbar ===== */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

    /* ===== Top Bar ===== */
    .top-bar {
      position: fixed;
      top: 0; right: 0; left: 0;
      z-index: 1000;
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.3s ease;
    }

    .top-bar.scrolled {
      padding: 8px 24px;
      background: rgba(10,10,15,0.97);
    }

    .logo-wrap {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-wrap img {
      height: 42px;
      filter: drop-shadow(0 0 8px rgba(201,168,76,0.6));
    }

    .logo-text {
      font-size: 1.05em;
      font-weight: 700;
      color: var(--gold-light);
      letter-spacing: 0.02em;
      line-height: 1.3;
    }

    .logo-text small {
      display: block;
      font-size: 0.72em;
      font-weight: 400;
      color: var(--text-muted);
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .notif-btn {
      position: relative;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      border-radius: 50%;
      transition: background 0.2s;
    }

    .notif-btn:hover { background: rgba(201,168,76,0.1); }

    .notif-btn img { width: 24px; height: 24px; filter: brightness(0) invert(1); opacity: 0.8; }

    #notif-badge {
      position: absolute;
      top: 0; right: 0;
      background: #E53E3E;
      color: white;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 5px;
      border-radius: 10px;
      display: none;
    }

    .datetime-pill {
      background: rgba(201,168,76,0.12);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 0.78em;
      color: var(--gold-light);
      display: none;
    }

    @media (min-width: 640px) { .datetime-pill { display: block; } }

    .menu-btn {
      background: none;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 7px 10px;
      cursor: pointer;
      color: var(--gold-light);
      font-size: 20px;
      line-height: 1;
      transition: all 0.2s;
    }

    .menu-btn:hover {
      background: rgba(201,168,76,0.1);
      border-color: var(--gold);
    }

    /* ===== Sidebar ===== */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 1999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .sidebar-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .sidebar {
      position: fixed;
      top: 0; right: 0;
      width: 280px;
      height: 100%;
      background: var(--dark-2);
      border-left: 1px solid var(--border);
      z-index: 2000;
      transform: translateX(100%);
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
      overflow-y: auto;
      padding-bottom: 80px;
    }

    .sidebar.open { transform: translateX(0); }

    .sidebar-header {
      padding: 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .sidebar-title {
      font-size: 1em;
      font-weight: 700;
      color: var(--gold-light);
    }

    .close-btn {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 24px;
      cursor: pointer;
      line-height: 1;
      padding: 4px;
      border-radius: 6px;
      transition: color 0.2s;
    }

    .close-btn:hover { color: var(--white); }

    .sidebar nav a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 20px;
      color: var(--cream);
      text-decoration: none;
      font-size: 0.95em;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: all 0.2s;
    }

    .sidebar nav a:hover {
      background: rgba(201,168,76,0.08);
      color: var(--gold-light);
      padding-right: 28px;
    }

    .sidebar nav a .icon { font-size: 1.2em; }

    /* ===== Hero Section ===== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 100px 20px 120px;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://travilia.com/uploads/0000/8/2024/09/26/hajj-rituals-makkah-accorhotels.jpg');
      background-size: cover;
      background-position: center top;
      transform: scale(1.05);
      animation: heroZoom 20s ease-in-out infinite alternate;
    }

    @keyframes heroZoom {
      from { transform: scale(1.05); }
      to   { transform: scale(1.12); }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10,10,15,0.55) 0%,
        rgba(10,10,15,0.30) 40%,
        rgba(10,10,15,0.70) 75%,
        rgba(10,10,15,1.00) 100%
      );
    }

    /* Animated stars/particles */
    .particles {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .particle {
      position: absolute;
      width: 2px;
      height: 2px;
      background: var(--gold-glow);
      border-radius: 50%;
      opacity: 0;
      animation: twinkle var(--dur, 4s) var(--delay, 0s) infinite ease-in-out;
    }

    @keyframes twinkle {
      0%,100% { opacity: 0; transform: scale(0.5); }
      50%      { opacity: 0.8; transform: scale(1.5); }
    }

    /* Geometric decorative ring */
    .kaaba-ring {
      position: absolute;
      width: 520px;
      height: 520px;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.12);
      top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      animation: ringPulse 6s ease-in-out infinite;
    }

    .kaaba-ring::before {
      content: '';
      position: absolute;
      inset: 20px;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.18);
      animation: ringPulse 6s ease-in-out infinite reverse;
    }

    .kaaba-ring::after {
      content: '';
      position: absolute;
      inset: 40px;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.25);
    }

    @keyframes ringPulse {
      0%,100% { opacity: 0.6; transform: translate(-50%,-50%) scale(1); }
      50%      { opacity: 1;   transform: translate(-50%,-50%) scale(1.02); }
    }

    /* Hero content */
    .hero-content {
      position: relative;
      z-index: 5;
      text-align: center;
      max-width: 780px;
      animation: heroFadeIn 1.2s ease forwards;
    }

    @keyframes heroFadeIn {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.4);
      border-radius: 30px;
      padding: 6px 18px;
      font-size: 0.85em;
      color: var(--gold-light);
      margin-bottom: 24px;
      animation: heroFadeIn 1.2s 0.2s ease both;
    }

    .hero-badge .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--gold-glow);
      animation: blink 1.5s infinite;
    }

    @keyframes blink {
      0%,100% { opacity: 1; }
      50%      { opacity: 0.3; }
    }

    .hero-title {
      font-family: 'Amiri', serif;
      font-size: clamp(2.2em, 6vw, 4em);
      font-weight: 700;
      line-height: 1.3;
      color: var(--white);
      margin-bottom: 8px;
      animation: heroFadeIn 1.2s 0.4s ease both;
    }

    .hero-title span {
      background: linear-gradient(135deg, var(--gold-glow), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-name {
      font-size: clamp(0.9em, 2vw, 1.15em);
      color: var(--text-muted);
      margin-bottom: 28px;
      font-weight: 400;
      animation: heroFadeIn 1.2s 0.5s ease both;
    }

    .hero-name strong {
      color: var(--gold-light);
      font-weight: 600;
    }

    .hero-desc {
      font-size: clamp(1em, 2.5vw, 1.25em);
      color: rgba(255,255,255,0.75);
      line-height: 1.8;
      margin-bottom: 40px;
      animation: heroFadeIn 1.2s 0.6s ease both;
    }

    .hero-cta {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
      animation: heroFadeIn 1.2s 0.8s ease both;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, var(--gold-glow), var(--gold));
      color: #000;
      padding: 15px 32px;
      font-family: 'Tajawal', sans-serif;
      font-size: 1.05em;
      font-weight: 700;
      border-radius: 50px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 8px 32px rgba(201,168,76,0.35);
      position: relative;
      overflow: hidden;
    }

    .btn-primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0);
      transition: background 0.3s;
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 42px rgba(201,168,76,0.5);
    }

    .btn-primary:hover::before { background: rgba(255,255,255,0.1); }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      color: var(--gold-light);
      padding: 14px 30px;
      font-family: 'Tajawal', sans-serif;
      font-size: 1.05em;
      font-weight: 600;
      border-radius: 50px;
      text-decoration: none;
      border: 1.5px solid rgba(201,168,76,0.5);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-secondary:hover {
      background: rgba(201,168,76,0.1);
      border-color: var(--gold);
      transform: translateY(-3px);
    }

    /* ===== Stats Strip ===== */
    .stats-strip {
      position: relative;
      z-index: 5;
      display: flex;
      justify-content: center;
      gap: 0;
      margin-top: 60px;
      animation: heroFadeIn 1.2s 1s ease both;
      flex-wrap: wrap;
    }

    .stat-item {
      padding: 16px 36px;
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .stat-item:last-child { border-right: none; }

    .stat-num {
      font-size: 1.9em;
      font-weight: 800;
      background: linear-gradient(135deg, var(--gold-glow), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
    }

    .stat-label {
      font-size: 0.8em;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* ===== Scroll indicator ===== */
    .scroll-hint {
      position: absolute;
      bottom: 90px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      color: var(--text-muted);
      font-size: 0.78em;
      animation: float 2s ease-in-out infinite;
    }

    @keyframes float {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50%      { transform: translateX(-50%) translateY(6px); }
    }

    .scroll-arrow {
      width: 24px; height: 24px;
      border-right: 1.5px solid var(--gold);
      border-bottom: 1.5px solid var(--gold);
      transform: rotate(45deg);
    }

    /* ===== Features Section ===== */
    .section {
      padding: 80px 24px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      display: inline-block;
      background: rgba(201,168,76,0.1);
      border: 1px solid var(--border);
      border-radius: 30px;
      padding: 5px 16px;
      font-size: 0.8em;
      color: var(--gold);
      margin-bottom: 16px;
      letter-spacing: 0.05em;
    }

    .section-title {
      font-family: 'Amiri', serif;
      font-size: clamp(1.8em, 4vw, 2.8em);
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
      line-height: 1.3;
    }

    .section-title span {
      background: linear-gradient(135deg, var(--gold-glow), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-sub {
      font-size: 1em;
      color: var(--text-muted);
      margin-bottom: 48px;
      max-width: 500px;
    }

    /* Features Grid */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .feature-card {
      background: var(--dark-2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px;
      transition: all 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 80px; height: 80px;
      background: radial-gradient(circle at top right, rgba(201,168,76,0.12), transparent 70%);
      border-radius: 0 20px 0 0;
    }

    .feature-card:hover {
      border-color: rgba(201,168,76,0.5);
      transform: translateY(-6px);
      box-shadow: var(--shadow-gold);
    }

    .feature-icon {
      width: 52px; height: 52px;
      background: linear-gradient(135deg, rgba(201,168,76,0.2), rgba(201,168,76,0.05));
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5em;
      margin-bottom: 18px;
    }

    .feature-title {
      font-size: 1.1em;
      font-weight: 700;
      color: var(--cream);
      margin-bottom: 10px;
    }

    .feature-desc {
      font-size: 0.9em;
      color: var(--text-muted);
      line-height: 1.7;
    }

    /* ===== Quick Access ===== */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-top: 40px;
    }

    .quick-card {
      background: var(--dark-3);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
      text-decoration: none;
      text-align: center;
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .quick-card:hover {
      background: rgba(201,168,76,0.08);
      border-color: var(--gold);
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(201,168,76,0.15);
    }

    .quick-card .q-icon { font-size: 2em; }

    .quick-card .q-label {
      font-size: 0.9em;
      font-weight: 600;
      color: var(--cream);
    }

    .quick-card .q-desc {
      font-size: 0.78em;
      color: var(--text-muted);
    }

    /* ===== Divider ===== */
    .divider {
      border: none;
      height: 1px;
      background: linear-gradient(to left, transparent, var(--border), transparent);
      margin: 0;
    }

    /* ===== CTA Banner ===== */
    .cta-banner {
      background: linear-gradient(135deg, var(--dark-2), var(--dark-3));
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 48px 36px;
      text-align: center;
      position: relative;
      overflow: hidden;
      margin: 0 24px;
    }

    .cta-banner::before {
      content: '🕋';
      position: absolute;
      font-size: 180px;
      opacity: 0.04;
      top: 50%;
      left: 50%;
      transform: translate(-50%,-50%);
      pointer-events: none;
    }

    .cta-banner h2 {
      font-family: 'Amiri', serif;
      font-size: clamp(1.5em, 3.5vw, 2.2em);
      color: var(--white);
      margin-bottom: 14px;
    }

    .cta-banner p {
      color: var(--text-muted);
      margin-bottom: 28px;
      font-size: 1em;
    }

    .cta-banner .cta-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ===== Footer ===== */
    footer {
      background: var(--dark-2);
      border-top: 1px solid var(--border);
      padding: 24px;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.85em;
      margin-bottom: 70px;
    }

    footer a { color: var(--gold); text-decoration: none; }

    /* ===== Bottom Nav ===== */
    .bottom-nav {
      position: fixed;
      bottom: 0; right: 0; left: 0;
      z-index: 1000;
      background: rgba(18,18,26,0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-around;
      padding: 10px 0 12px;
    }

    .bottom-nav a {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.7em;
      font-weight: 500;
      transition: color 0.2s;
      padding: 4px 12px;
      border-radius: 10px;
    }

    .bottom-nav a:hover, .bottom-nav a.active {
      color: var(--gold-light);
    }

    .bottom-nav a .nav-icon { font-size: 1.4em; }

    .flag {
      position: fixed;
      bottom: 85px;
      left: 16px;
      width: 50px;
      z-index: 999;
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
      animation: flagWave 3s ease-in-out infinite;
      transform-origin: right center;
    }

    @keyframes flagWave {
      0%,100% { transform: rotate(0deg); }
      25%      { transform: rotate(4deg); }
      75%      { transform: rotate(-3deg); }
    }

    /* ===== Responsive ===== */
    @media (max-width: 600px) {
      .stat-item { padding: 12px 20px; }
      .stat-num  { font-size: 1.5em; }
      .section   { padding: 60px 16px; }
      .cta-banner { padding: 32px 20px; margin: 0 16px; }
      .quick-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

